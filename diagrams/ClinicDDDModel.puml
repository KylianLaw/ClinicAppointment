@startuml
title Clinic Appointment Booking - DDD Domain Model

hide circle
top to bottom direction
scale 0.2

!define ENTITY(entityName) class entityName << Entity >>
!define ENUM(enumName) class enumName << Enum >>
!define AGGREGATE_ROOT(aggregateRootName) class aggregateRootName << Aggregate Root >>
!define VALUE_OBJECT(valueObjectName) class valueObjectName << Value Object >>

skinparam dpi 350
skinparam packageStyle rectangle
skinparam rectangle {
    BackgroundColor #f7f4eb
    BorderColor Black
}

skinparam class {
    BorderColor Black
    BackgroundColor White
}

rectangle "Clinic Appointment Booking Context" as ClinicBC #line.dashed {

    package "Patient Management Sub-Domain (SUPPORTING)" as PatientSD #ADD8E6 {
        AGGREGATE_ROOT(Patient) #87CEEB {
            patientId: UUID
            firstName: String
            lastName: String
            birthDate: Date
        }

        VALUE_OBJECT(PatientIdentifier) #F5F5F5 {
            patientId: UUID
        }

        VALUE_OBJECT(PatientAddress) #F5F5F5 {
            street: String
            city: String
            postalCode: String
        }

        VALUE_OBJECT(PatientContactInfo) #F5F5F5 {
            email: String
            phoneNumber: String
        }

        Patient "1" -- "1" PatientAddress
        Patient "1" -- "1" PatientContactInfo

        note right of Patient #FFF3B0
        Invariants:
        - Patient full name cannot be null or blank
        - Birth date cannot be null
        - Patient address must be provided
        - Patient contact info must be provided
        - Duplicate patient must not exist
        end note
    }

    package "Doctor Management Sub-Domain (SUPPORTING)" as DoctorSD #C1E1C1 {
        AGGREGATE_ROOT(Doctor) #90EE90 {
            doctorId: UUID
            firstName: String
            lastName: String
            specialty: SpecialtyEnum
        }

        VALUE_OBJECT(DoctorIdentifier) #F5F5F5 {
            doctorId: UUID
        }

        VALUE_OBJECT(DoctorContactInfo) #F5F5F5 {
            email: String
            phoneNumber: String
        }

        ENUM(SpecialtyEnum) #E6E6E6 {
            PEDIATRICS
            DERMATOLOGY
            PSYCHIATRY
            CARDIOLOGY
            ORTHOPEDICS
            NEUROLOGY
            FAMILY_MEDICINE
        }

        Doctor "1" -- "1" DoctorContactInfo

        note right of Doctor #FFF3B0
        Invariants:
        - Doctor full name cannot be null or blank
        - Specialty cannot be null
        - Duplicate doctor must not exist
        end note
    }

    package "Clinic Management Sub-Domain (SUPPORTING)" as ClinicSD #FFD8A8 {
        AGGREGATE_ROOT(Clinic) #FFB347 {
            clinicId: UUID
            clinicName: String
        }

        VALUE_OBJECT(ClinicIdentifier) #F5F5F5 {
            clinicId: UUID
        }

        VALUE_OBJECT(ClinicAddress) #F5F5F5 {
            street: String
            city: String
            postalCode: String
        }

        Clinic "1" -- "1" ClinicAddress

        note right of Clinic #FFF3B0
        Invariants:
        - Clinic name cannot be null or blank
        - Clinic address must be provided
        - Street, city, and postal code cannot be null or blank
        - Duplicate clinic must not exist
        end note
    }

    package "Appointment Management Sub-Domain (CORE)" as AppointmentSD #E6D9FF {

        ' =========================
        ' AGGREGATE 1 : Appointment
        ' =========================

        AGGREGATE_ROOT(Appointment) #CDB4FF {
            appointmentId: UUID
            patientId: UUID
            doctorId: UUID
            clinicId: UUID
            appointmentDateTime: LocalDateTime
            appointmentStatus: AppointmentStatusEnum
        }

        VALUE_OBJECT(AppointmentIdentifier) #F5F5F5 {
            appointmentId: UUID
        }

        ENUM(AppointmentStatusEnum) #E6E6E6 {
            SCHEDULED
            CANCELLED
            COMPLETED
        }

        Appointment --> AppointmentStatusEnum
        Appointment --> AppointmentIdentifier

        ' references to other aggregates via identifiers only
        Appointment -d-> PatientIdentifier
        Appointment -d-> DoctorIdentifier
        Appointment -d-> ClinicIdentifier

        note right of Appointment #FFF3B0
        Invariants:
        - Appointment cannot be scheduled in the past
        - Patient cannot have overlapping appointments
        - CANCELLED appointment cannot become COMPLETED
        end note


        ' =========================
        ' AGGREGATE 2 : AppointmentFollowUpPlan
        ' =========================

        AGGREGATE_ROOT(AppointmentFollowUpPlan) #CDB4FF {
            followUpPlanId: UUID
            appointmentId: UUID
            patientId: UUID
            doctorId: UUID
            clinicId: UUID
            recommendedFollowUpDate: LocalDateTime
            followUpReason: String
            status: FollowUpPlanStatusEnum
        }

        VALUE_OBJECT(AppointmentFollowUpPlanIdentifier) #F5F5F5 {
            followUpPlanId: UUID
        }

        ENUM(FollowUpPlanStatusEnum) #E6E6E6 {
            PLANNED
            COMPLETED
            CANCELLED
        }

        AppointmentFollowUpPlan --> AppointmentFollowUpPlanIdentifier
        AppointmentFollowUpPlan --> FollowUpPlanStatusEnum

        ' references to other aggregates via identifiers only
        AppointmentFollowUpPlan -d-> AppointmentIdentifier
        AppointmentFollowUpPlan -d-> PatientIdentifier
        AppointmentFollowUpPlan -d-> DoctorIdentifier
        AppointmentFollowUpPlan -d-> ClinicIdentifier

        note right of AppointmentFollowUpPlan #FFF3B0
        Invariants:
        - Follow-up plan must reference a valid appointment
        - recommendedFollowUpDate must be after the original appointmentDateTime
        - A COMPLETED follow-up plan cannot become PLANNED again
        - A CANCELLED follow-up plan cannot become COMPLETED
        end note

        ' =========================
        ' CORE SUBDOMAIN RELATIONS
        ' =========================

        AppointmentSD -d-> PatientSD : "Associate appointment with patient"
        AppointmentSD -d-> DoctorSD  : "Check doctor availability"
        AppointmentSD -d-> ClinicSD  : "Schedule appointment at clinic"
    }
}
@enduml